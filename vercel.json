{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/auto-discover.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/trend.html", "dest": "/trend.html" },
    { "src": "/ai.html",    "dest": "/ai.html" },
    { "src": "/data.html",  "dest": "/data.html" },
    { "src": "/",           "dest": "/index.html" }
  ]
}
