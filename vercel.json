{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/auto-discover.js":           { "maxDuration": 300 },
    "api/hot-analyze.js":             { "maxDuration": 120 },
    "api/google-trends-rss.js":       { "maxDuration": 10  },
    "api/blog-generate.js":           { "maxDuration": 60  },
    "api/fetch-url.js":               { "maxDuration": 30  },
    "api/proxy-image.js":             { "maxDuration": 30  },
    "api/coupang-search.js":          { "maxDuration": 15  },
    "api/fetch-coupang-product.js":   { "maxDuration": 15  },
    "api/analyze-image.js":           { "maxDuration": 60  },
    "api/generate-image.js":          { "maxDuration": 90  },
    "api/naver-shop.js":              { "maxDuration": 15  },
    "api/naver-search.js":            { "maxDuration": 15  }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/",         "dest": "/index.html" },
    { "src": "/hot.html",   "dest": "/hot.html"   },
    { "src": "/trend.html", "dest": "/trend.html" },
    { "src": "/blog.html",  "dest": "/blog.html"  },
    { "src": "/data.html",  "dest": "/data.html"  },
    { "src": "/image.html", "dest": "/image.html" },
    { "src": "/(.*)",     "dest": "/$1"           }
  ]
}
